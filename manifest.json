{
  "manifest_version": 3,
  "name": "MACS-FC: Universal File Compression",
  "version": "1.0.0",
  "description": "Universal File Compressor. Supports lossless and lossy compression for text, images, audio, and video.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Open MACS-FC"
  },
  "icons": {
    "16": "assets/macs-logo.png",
    "48": "assets/macs-logo.png",
    "128": "assets/macs-logo.png"
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "permissions": [
    "storage",
    "unlimitedStorage",
    "offscreen"
  ],
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "lib/ffmpeg-core.js",
        "lib/ffmpeg-core.wasm"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
  }
}